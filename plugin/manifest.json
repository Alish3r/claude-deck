{
  "UUID": "com.alisher.claude-deck",
  "SDKVersion": 2,
  "Author": "alisher",
  "Name": "Claude Deck",
  "Version": "0.1.0.0",
  "Description": "Control Claude Code model & effort from Stream Deck + dials, per focused chat.",
  "Category": "Claude Deck",
  "CategoryIcon": "imgs/plugin/category",
  "Icon": "imgs/plugin/marketplace",
  "Nodejs": { "Version": "20" },
  "CodePath": "src/plugin.js",
  "Software": { "MinimumVersion": "6.5" },
  "OS": [{ "Platform": "windows", "MinimumVersion": "10" }],
  "Actions": [
    {
      "Name": "Model",
      "UUID": "com.alisher.claude-deck.model",
      "Icon": "imgs/actions/model/icon",
      "Controllers": ["Encoder"],
      "Encoder": {
        "layout": "layouts/dial.json",
        "TriggerDescription": { "Rotate": "Browse model", "Push": "/compact" }
      },
      "States": [{ "Image": "imgs/actions/model/key", "TitleAlignment": "middle" }]
    },
    {
      "Name": "Effort",
      "UUID": "com.alisher.claude-deck.effort",
      "Icon": "imgs/actions/effort/icon",
      "Controllers": ["Encoder"],
      "Encoder": {
        "layout": "layouts/dial.json",
        "TriggerDescription": { "Rotate": "Set effort (⊙GLOBAL)", "Push": "Toggle thinking" }
      },
      "States": [{ "Image": "imgs/actions/effort/key", "TitleAlignment": "middle" }]
    }
  ]
}
